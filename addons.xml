<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.flixtor" name="Flixtor Repository" version="1.0.0" provider-name="Anthony Curare">
    <extension point="xbmc.addon.repository" name="Flixtor Repository">
        <info compressed="false">https://anieto-lab.github.io/kodi-repo/addons.xml</info>
        <checksum>https://anieto-lab.github.io/kodi-repo/addons.xml.md5</checksum>
        <datadir zip="true">https://anieto-lab.github.io/kodi-repo</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Flixtor addon repository</summary>
        <description lang="en">Repository for installing and updating the Flixtor Kodi addon.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="plugin.video.flixtor" name="Flixtor" version="1.8.0" provider-name="Anthony Curare">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Flixtor VIP streaming</summary>
        <description lang="en">Browse and stream movies and TV shows from Flixtor using your VIP account.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>
